# ============================================
# ROTIQ - Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env.local e preencha com seus valores
# Este arquivo documenta TODAS as variáveis necessárias

# ============================================
# BANCO DE DADOS (PostgreSQL)
# ============================================
# Para desenvolvimento local no Windows:
# DATABASE_URL=postgresql://usuario:senha@localhost:5432/rotiq
# Para Railway ou Vercel, a variável será fornecida automaticamente
DATABASE_URL=postgresql://user:password@localhost:5432/rotiq

# ============================================
# AUTENTICAÇÃO E SEGURANÇA
# ============================================
# JWT Secret para assinatura de sessões
# Gere uma chave forte: openssl rand -base64 32
JWT_SECRET=sua_chave_secreta_muito_segura_aqui_minimo_32_caracteres

# OAuth Server URL (Manus OAuth - OPCIONAL)
# Se não configurado, o sistema usará autenticação local
# Deixe vazio ou remova para desabilitar OAuth
OAUTH_SERVER_URL=https://oauth.manus.im

# ID da aplicação (Manus - OPCIONAL)
VITE_APP_ID=seu_app_id_aqui

# Owner OpenID (Manus - OPCIONAL)
# Para definir o primeiro admin do sistema
OWNER_OPEN_ID=seu_owner_open_id

# ============================================
# AMBIENTE
# ============================================
NODE_ENV=development
# Valores: development, production, staging

# ============================================
# SERVIDOR
# ============================================
PORT=3000

# Frontend URL (para CORS)
FRONTEND_URL=http://localhost:5173

# ============================================
# APIS EXTERNAS (OPCIONAL)
# ============================================
# Arquivei (Qive) - Para integração com NF-e
# Você pode configurar isso dentro do sistema também
ARQUIVEI_APP_ID=seu_app_id_arquivei
ARQUIVEI_API_KEY=sua_api_key_arquivei

# ============================================
# VERCEL (Frontend)
# ============================================
VITE_API_URL=https://seu-backend-url.railway.app
VITE_APP_NAME=Rotiq

# ============================================
# NOTAS IMPORTANTES
# ============================================
# 1. Em produção (Railway/Vercel), as variáveis são definidas no painel da plataforma
# 2. Nunca commite o arquivo .env com dados reais no Git
# 3. Use .env.local para desenvolvimento local
# 4. DATABASE_URL é fornecido automaticamente pelo Railway
# 5. OAUTH_SERVER_URL é OPCIONAL - o sistema funciona sem ele
