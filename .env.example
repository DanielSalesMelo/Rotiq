# Database Configuration (PostgreSQL)
# Para desenvolvimento local no Windows:
# DATABASE_URL=postgresql://usuario:senha@localhost:5432/rotiq
# Para Railway ou Vercel, a variável será fornecida automaticamente
DATABASE_URL=postgresql://user:password@localhost:5432/rotiq

# OAuth Configuration
OAUTH_SERVER_URL=https://seu-oauth-server.com

# Node Environment
NODE_ENV=development

# Server Port
PORT=3000

# Frontend URL (para CORS)
FRONTEND_URL=http://localhost:5173

# Owner OpenID (para definir o primeiro admin)
OWNER_OPEN_ID=seu-open-id-aqui
