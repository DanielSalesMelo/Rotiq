{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "rootDir": ".",
    "esModuleInterop": true,
    "strict": false,\n    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "types": ["node"]
  },
  "include": ["./**/*.ts"],
  "exclude": [
    "**/*.test.ts",
    "../drizzle",
    "../shared",
    "../node_modules",
    "node_modules"
  ]
}
