{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "buildCommand": "npm install --prefix server && npm run build --prefix server"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "node server/dist/index.js",
    "restartPolicyMaxRetries": 5
  }
}
