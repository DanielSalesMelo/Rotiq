{
  "buildCommand": "cd client && npm run build",
  "outputDirectory": "client/dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/trpc/:path*",
      "destination": "https://rotiq-production.up.railway.app/api/trpc/:path*"
    },
    {
      "source": "/login",
      "destination": "/"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ],
  "env": {
    "DATABASE_URL": "@rotiq_database_url",
    "OAUTH_SERVER_URL": "@rotiq_oauth_server_url",
    "OWNER_OPEN_ID": "@rotiq_owner_open_id"
  }
}
