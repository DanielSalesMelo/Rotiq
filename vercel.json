{
  "version": 2,
  "framework": "vite",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "env": {
    "VITE_API_URL": "https://rotiq-production.up.railway.app"
  },
  "rewrites": [
    {
      "source": "/api/trpc/:path*",
      "destination": "https://rotiq-production.up.railway.app/api/trpc/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
